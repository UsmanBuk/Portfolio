{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["name", "role", "skills", "active"],
  "properties": {
    "name": { "type": "string" },
    "role": { "type": "string" },
    "skills": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "active": { "type": "boolean" }
  },
  "additionalProperties": false
}
